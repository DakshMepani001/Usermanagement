{
  "info": {
    "name": "User Management API (CRUD)",
    "description": "Postman collection for testing user CRUD operations",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:5121"
    },
    {
      "key": "authToken",
      "value": "dev-token-change-me"
    },
    {
      "key": "userId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create user (POST /api/users)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
            },
            {
              "key": "Authorization",
              "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Asha\",\n  \"lastName\": \"Patel\",\n  \"email\": \"asha.patel@example.com\",\n  \"phone\": \"+15551234567\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.environment.set('userId', json.id);",
              "console.log('Created userId:', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Get all users (GET /api/users)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users"
          ]
        }
        ,
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    },
    {
      "name": "Get user by id (GET /api/users/{id})",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "{{userId}}"
          ]
        }
        ,
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    },
    {
      "name": "Update user (PUT /api/users/{id})",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
            },
            {
              "key": "Authorization",
              "value": "Bearer {{authToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "{{userId}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Asha\",\n  \"lastName\": \"Patel\",\n  \"email\": \"asha.patel.updated@example.com\",\n  \"phone\": \"+15557654321\"\n}"
        }
      }
    },
    {
      "name": "Delete user (DELETE /api/users/{id})",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{baseUrl}}/api/users/{{userId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "{{userId}}"
          ]
        }
        ,
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{authToken}}"
          }
        ]
      }
    }
  ]
}

